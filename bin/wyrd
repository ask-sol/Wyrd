#!/usr/bin/env node
import { main } from '../dist/cli/main.js';

main(process.argv.slice(2)).then(
  (code) => process.exit(code ?? 0),
  (err) => {
    const msg = err && typeof err === 'object' && 'message' in err ? err.message : String(err);
    process.stderr.write('wyrd: ' + msg + '\n');
    process.exit(1);
  },
);
